rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    //  دوال مساعدة
    // ============================================================

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidProduct() {
      return request.resource.data.keys().hasAll(['name', 'price', 'category']) &&
        request.resource.data.name is string &&
        request.resource.data.price is number &&
        request.resource.data.category is string;
    }

    // ============================================================
    //  المحتوى العام (قراءة للجميع، كتابة للمدير فقط)
    // ============================================================

    match /categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{doc} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct();
    }

    match /banners/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offers/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contacts/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    //  الطلبات
    // ============================================================
    match /orders/{orderId} {
      allow read: if isLoggedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    //  الوصفات الطبية
    // ============================================================
    match /prescriptions/{doc} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    //  بيانات المستخدمين
    // ============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);

      match /favorites/{favId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addrId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ============================================================
    //  التقييمات
    // ============================================================
    match /reviews/{doc} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update, delete: if isOwner(request.resource.data.userId) || isAdmin();
    }
  }
}
