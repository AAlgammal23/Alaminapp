rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
    }
    match /{document=**} {
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/admins).data.adminIds;
    }
  }
}
